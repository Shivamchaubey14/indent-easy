# ---------------------------------------------------------------------------
# Environment configuration for Indent Easy (copy to .env and fill in values)
# The real .env is gitignored and must NEVER be committed.
# ---------------------------------------------------------------------------

# Django
SECRET_KEY=django-insecure-change-me-to-a-long-random-string

# Database (MySQL)
DATABASE_NAME=your_db_name
DATABASE_USER=your_db_user
DATABASE_PASSWORD=your_db_password
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306

# Generic API key used by the app
API_KEY=your_api_key

# WhatsApp Cloud API (Meta)
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WABA_ID=your_whatsapp_business_account_id
API_VERSION=v22.0
BASE_URL=https://graph.facebook.com
TEMPLATE_NAME=your_template_name
TEMPLATE_LANGUAGE=hi
BUSINESS_NAME=Your Business Name
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token
WHATSAPP_WEBHOOK_SECRET=your_webhook_secret

# Email (Gmail SMTP – use an app password)
EMAIL_HOST_USER=you@example.com
EMAIL_HOST_PASSWORD=your_gmail_app_password

# Comma-separated list of trusted origins for CSRF
CSRF_TRUSTED_ORIGINS=https://your-domain.com
